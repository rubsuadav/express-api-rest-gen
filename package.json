{
  "name": "express-api-rest-gen",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/bin/index.js",
    "dev": "tsx bin/index.ts",
    "test": "jest --coverage"
  },
  "bin": {
    "express-api-rest-gen": "dist/bin/index.js"
  },
  "version": "4.8.0",
  "main": "dist/bin/index.js",
  "keywords": [
    "express",
    "api",
    "rest",
    "generator"
  ],
  "files": [
    "README.md",
    "dist/**/*",
    "tsconfig.json"
  ],
  "repository": {
    "url": "https://github.com/rubsuadav/express-api-rest-gen",
    "type": "git"
  },
  "homepage": "https://github.com/rubsuadav/express-api-rest-gen",
  "author": "rubsuadav",
  "engines": {
    "node": ">=22.14.0",
    "npm": ">=10.9.2"
  },
  "license": "ISC",
  "description": "A minimal CLI tool to generate a REST API with Express with JS or TS",
  "dependencies": {
    "chalk": "^5.6.0",
    "inquirer": "^12.9.3",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
